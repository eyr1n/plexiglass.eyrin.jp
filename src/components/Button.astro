---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
  disabled?: boolean;
}

const { class: className, disabled, ...props } = Astro.props;
---

{
  disabled ? (
    <span
      class:list={[
        'cursor-not-allowed rounded-xl border-4 border-slate-300 text-slate-400',
        className,
      ]}
    >
      <slot />
    </span>
  ) : (
    <a
      class:list={[
        'rounded-xl border-4 border-slate-700 text-slate-800 transition hover:bg-slate-700 hover:text-white',
        className,
      ]}
      {...props}
    >
      <slot />
    </a>
  )
}
